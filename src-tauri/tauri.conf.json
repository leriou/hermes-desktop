{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hermes-desktop",
  "version": "0.1.0",
  "identifier": "com.nousresearch.hermes",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:19642",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Hermes Agent",
        "width": 1100,
        "height": 850,
        "minWidth": 900,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://data; font-src 'self' asset:; connect-src 'self' http://localhost:* http://127.0.0.1:* https:; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
