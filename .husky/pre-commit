#!/usr/bin/env sh

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$BRANCH" in
  release|release/*) ;;
  *)
    exit 0
    ;;
esac

echo "→ [pre-commit] Release branch — running lint..."
bun run lint || { echo "✗ Lint failed. Commit aborted."; exit 1; }

echo "→ [pre-commit] Running tests..."
bun run test || { echo "✗ Tests failed. Commit aborted."; exit 1; }

echo "✓ [pre-commit] Lint and tests passed."
