{
  "name": "hermes-desktop",
  "version": "0.4.5",
  "description": "Hermes Agent Desktop — self-improving AI assistant",
  "author": "fathah",
  "homepage": "https://github.com/fathah/hermes-desktop",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.web.json --composite false",
    "dev": "vite --config vite.tauri.config.ts",
    "dev:tauri": "vite --config vite.tauri.config.ts",
    "build": "vite --config vite.tauri.config.ts build",
    "build:tauri": "vite --config vite.tauri.config.ts build",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "i18next": "^25.6.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.7.0",
    "posthog-js": "^1.376.0",
    "react-i18next": "^15.7.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.4"
  }
}
